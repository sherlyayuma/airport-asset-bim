{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://airport-asset-bim.vercel.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://airport-asset-bim.vercel.app/uploads/:path*"
    },
    {
      "source": "/barcodes/:path*",
      "destination": "https://airport-asset-bim.vercel.app/barcodes/:path*"
    }
  ]
}
