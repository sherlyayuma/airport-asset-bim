<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minangkabau Airport - Data Aset</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/style-mobile.css">
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
</head>

<body class="dashboard-body">

    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-brand">
            <div class="logo-circle">
                <img src="/assets/logo-injourney.png" alt="Injourney Logo">
            </div>
            <div class="brand-text">
                <h3 style="color: #111827; font-size: 0.9rem; font-weight: 700;">Minangkabau <br> Airport</h3>
            </div>
        </div>

        <ul class="nav-links">
            <li>
                <a href="dashboard.html">
                    <i class="ph ph-squares-four"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="active">
                <a href="#">
                    <i class="ph ph-cube"></i>
                    <span>Data Aset</span>
                </a>
            </li>
            <li>
                <a href="laporan-aset.html">
                    <i class="ph ph-file-text"></i>
                    <span>Laporan Aset</span>
                </a>
            </li>
            <li>
                <a href="laporan.html">
                    <i class="ph ph-scan"></i>
                    <span>Scan Aset</span>
                </a>
            </li>
            <li>
                <a href="cetak-qr.html">
                    <i class="ph ph-qr-code"></i>
                    <span>Cetak QR</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <button id="logout-btn" class="logout-link">
                <i class="ph ph-sign-out"></i>
                <span>Logout</span>
            </button>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="top-header">
            <button id="menu-toggle" class="menu-toggle-btn">
                <i class="ph ph-list"></i>
            </button>
            <div class="header-logos">
                <div class="logo-circle">
                    <img src="/assets/logo-minangkabau.jpg" alt="Logo MIA">
                </div>
            </div>
            <div class="brand-text-container">
                <h2>Data Aset</h2>
                <p class="subtitle">Kelola inventaris aset bandara, pantau kondisi, dan lokasi aset.</p>
            </div>
            <div class="header-right">
                <a href="tambah-aset.html" class="btn-primary" style="text-decoration: none;">
                    <i class="ph-bold ph-plus"></i>
                    <span>Tambah Aset</span>
                </a>

            </div>
        </header>

        <!-- Filter Section -->
        <div class="filter-bar card">
            <div class="search-input">
                <i class="ph ph-magnifying-glass"></i>
                <input type="text" placeholder="Cari Asset atau Description...">
            </div>
            <div class="filter-dropdowns" style="display: flex; gap: 12px; align-items: center;">
                <select id="filter-tipe" class="form-select">
                    <option value="all">Semua Tipe</option>
                    <option value="Asset Tetap">Asset Tetap</option>
                    <option value="Aset Dibiayakan">Aset Dibiayakan</option>
                    <option value="AUC">AUC (Construction In Progress)</option>
                    <option value="Intangible Asset">Intangible Asset</option>
                </select>
                <select id="filter-kondisi" class="form-select">
                    <option value="all">Semua Kondisi</option>
                    <option value="Baik">Baik</option>
                    <option value="Rusak">Rusak</option>
                </select>
                <select id="filter-lokasi" class="form-select">
                    <option value="all">Semua Lokasi</option>
                </select>
            </div>
        </div>

        <!-- Asset Table -->
        <div class="table-section card no-padding">
            <table class="asset-table" id="asset-table">
                <thead>
                    <tr>
                        <th width="50">NO</th>
                        <th>ASSET</th>
                        <th>ASSET DESCRIPTION</th>
                        <th>TIPE ASET</th>
                        <th>LOKASI</th>
                        <th>KONDISI</th>
                        <th class="text-center" style="padding-right: 80px;">AKSI</th>
                    </tr>
                </thead>
                <tbody id="asset-table-body">
                    <!-- Data will be loaded via JS -->
                    <tr>
                        <td colspan="7" class="text-center" style="padding: 32px; color: var(--text-secondary);">
                            <i class="ph ph-spinner ph-spin" style="font-size: 24px;"></i> Memuat data aset...
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="pagination">
                <span class="page-info">Menampilkan 1-4 dari 128 aset</span>
                <div class="page-controls">
                    <button class="page-btn"><i class="ph ph-caret-left"></i></button>
                    <button class="page-btn active">1</button>
                    <button class="page-btn">2</button>
                    <button class="page-btn">3</button>
                    <span class="dots">...</span>
                    <button class="page-btn"><i class="ph ph-caret-right"></i></button>
                </div>
            </div>
        </div>

    </main>

    <!-- Modal Confirmation -->
    <div id="delete-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-icon">
                <i class="ph-fill ph-trash"></i>
            </div>
            <h3 class="modal-title">Hapus Aset?</h3>
            <p class="modal-desc" id="modal-desc-text">Apakah Anda yakin ingin menghapus aset ini? Tindakan ini tidak
                dapat dibatalkan.</p>
            <div class="modal-actions">
                <button class="btn-modal cancel" onclick="closeModal()">Batal</button>
                <button class="btn-modal confirm" id="confirm-delete-btn">Hapus</button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" class="toast-container"></div>

    <script src="/js/script.js"></script>
    <script>
        // Check Auth
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = 'index.html';
        }

        document.getElementById('logout-btn').addEventListener('click', () => {
            localStorage.removeItem('token');
            window.location.href = 'index.html';
        });

        // State
        let currentPage = 1;
        const limit = 10;
        let totalAssets = 0;

        // Elements
        const filterTipe = document.getElementById('filter-tipe');
        const filterKondisi = document.getElementById('filter-kondisi');
        const searchInput = document.querySelector('.search-input input');
        const tbody = document.getElementById('asset-table-body');
        const paginationContainer = document.querySelector('.pagination');

        // Initial Load
        document.addEventListener('DOMContentLoaded', () => {
            const params = new URLSearchParams(window.location.search);
            const searchParam = params.get('search');
            if (searchParam) {
                searchInput.value = searchParam;
            }
            fetchLocations();
            fetchAssets();
        });

        const filterLokasi = document.getElementById('filter-lokasi');

        // Events
        filterTipe.addEventListener('change', () => { currentPage = 1; fetchAssets(); });
        filterKondisi.addEventListener('change', () => { currentPage = 1; fetchAssets(); });
        filterLokasi.addEventListener('change', () => { currentPage = 1; fetchAssets(); });

        let debounceTimer;
        searchInput.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                currentPage = 1;
                fetchAssets();
            }, 500);
        });

        async function fetchLocations() {
            try {
                const response = await fetch('/api/locations', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.status === 401) {
                    localStorage.removeItem('token');
                    window.location.href = 'index.html';
                    return;
                }

                const result = await response.json();
                if (result.success) {
                    const select = document.getElementById('filter-lokasi');
                    select.innerHTML = '<option value="all">Semua Lokasi</option>';
                    result.locations.forEach(loc => {
                        const option = document.createElement('option');
                        option.value = loc.id;
                        option.textContent = loc.nama_lokasi;
                        select.appendChild(option);
                    });
                }
            } catch (e) {
                console.error("Error fetching locations", e);
            }
        }

        async function fetchAssets() {
            // Show loading
            tbody.innerHTML = `<tr><td colspan="7" class="text-center" style="padding: 32px;"><i class="ph ph-spinner ph-spin" style="font-size: 24px;"></i> Memuat data...</td></tr>`;

            const tipe = filterTipe.value;
            const kondisi = filterKondisi.value;
            const lokasi = filterLokasi.value;
            const search = searchInput.value;

            // Build Query
            const params = new URLSearchParams({
                page: currentPage,
                limit: limit,
                sort: 'newest'
            });
            if (tipe !== 'all') params.append('tipe', tipe);
            if (kondisi !== 'all') params.append('kondisi', kondisi);
            if (lokasi !== 'all') params.append('location_id', lokasi);
            if (search) params.append('search', search);

            try {
                const response = await fetch(`/api/assets?${params.toString()}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.status === 401) {
                    localStorage.removeItem('token');
                    window.location.href = 'index.html';
                    return;
                }

                const result = await response.json();

                if (result.success) {
                    renderTable(result.assets, (currentPage - 1) * limit);
                    renderPagination(result.pagination);
                } else {
                    tbody.innerHTML = `<tr><td colspan="7" class="text-center">Gagal memuat data: ${result.message}</td></tr>`;
                }
            } catch (error) {
                console.error('Error:', error);
                tbody.innerHTML = `<tr><td colspan="7" class="text-center">Terjadi kesalahan koneksi.</td></tr>`;
            }
        }

        function renderTable(assets, startIndex) {
            tbody.innerHTML = '';
            if (assets.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center" style="padding: 24px;">Data tidak ditemukan.</td></tr>`;
                return;
            }

            assets.forEach((asset, index) => {
                const tr = document.createElement('tr');

                // Badge Logic
                const lowerKondisi = (asset.kondisi || '').toLowerCase();
                let badgeClass = 'active'; // Green/Baik
                if (lowerKondisi === 'perbaikan') badgeClass = 'maintenance'; // Orange
                if (lowerKondisi === 'rusak' || lowerKondisi === 'hilang') badgeClass = 'damaged'; // Red

                tr.innerHTML = `
                    <td>${startIndex + index + 1}</td>
                    <td>
                        <div class="asset-name-cell">
                            <span class="fw-bold">${asset.nama}</span>

                        </div>
                    </td>
                    <td>${asset.description || '-'}</td>
                    <td>${asset.tipe_aset || '-'}</td>
                    <td>${asset.lokasi || '-'}</td>
                    <td><span class="badge ${badgeClass}">${asset.kondisi}</span></td>
                    <td class="text-center" style="padding-right: 80px;">
                        <a href="detail-aset.html?id=${asset.id}" class="action-btn edit" title="Lihat Detail">
                            <i class="ph-fill ph-eye"></i>
                        </a>
                        <button class="action-btn delete" onclick="deleteAsset(${asset.id}, '${asset.asset_id}')" title="Hapus">
                            <i class="ph-fill ph-trash"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function renderPagination(pagination) {
            const { page, total, totalPages } = pagination;

            // Info text
            const start = (page - 1) * limit + 1;
            const end = Math.min(page * limit, total);
            const infoText = total === 0 ? '0 aset' : `Menampilkan ${start}-${end} dari ${total} aset`;

            // Buttons logic
            let buttonsHtml = '';

            // Prev
            buttonsHtml += `<button class="page-btn" ${page === 1 ? 'disabled' : ''} onclick="changePage(${page - 1})"><i class="ph ph-caret-left"></i></button>`;

            // Pages
            // Simple logic: show all if <= 5, else show start, current, end with dots
            // For simplicity in this iteration, let's show simple range around current
            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= page - 1 && i <= page + 1)) {
                    buttonsHtml += `<button class="page-btn ${i === page ? 'active' : ''}" onclick="changePage(${i})">${i}</button>`;
                } else if (i === page - 2 || i === page + 2) {
                    buttonsHtml += `<span class="dots">...</span>`;
                }
            }

            // Next
            buttonsHtml += `<button class="page-btn" ${page === totalPages ? 'disabled' : ''} onclick="changePage(${page + 1})"><i class="ph ph-caret-right"></i></button>`;

            paginationContainer.innerHTML = `
                <span class="page-info">${infoText}</span>
                <div class="page-controls">
                    ${buttonsHtml}
                </div>
            `;
        }

        window.changePage = (newPage) => {
            currentPage = newPage;
            fetchAssets();
        };

        // Modal & Toast Logic
        let assetToDeleteId = null;
        let assetToDeleteCode = null;

        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;

            const icon = type === 'success' ? 'ph-check-circle' : 'ph-warning-circle';

            toast.innerHTML = `
                <i class="ph-fill ${icon} toast-icon"></i>
                <span class="toast-message">${message}</span>
            `;

            container.appendChild(toast);

            // Trigger animation
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });

            // Remove after 3s
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        window.deleteAsset = (id, assetId) => {
            assetToDeleteId = id;
            assetToDeleteCode = assetId;
            document.getElementById('modal-desc-text').textContent = `Apakah Anda yakin ingin menghapus aset ${assetId}? Tindakan ini tidak dapat dibatalkan.`;
            const modal = document.getElementById('delete-modal');
            modal.style.display = 'flex';
            requestAnimationFrame(() => modal.classList.add('show'));
        };

        window.closeModal = () => {
            const modal = document.getElementById('delete-modal');
            modal.classList.remove('show');
            setTimeout(() => modal.style.display = 'none', 300);
            assetToDeleteId = null;
        };

        document.getElementById('confirm-delete-btn').addEventListener('click', async () => {
            if (!assetToDeleteId) return;

            const btn = document.getElementById('confirm-delete-btn');
            const originalText = btn.textContent;
            btn.textContent = 'Menghapus...';
            btn.disabled = true;

            try {
                const response = await fetch(`/api/assets/delete/${assetToDeleteId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (response.status === 401) {
                    alert('Sesi habis. Silakan login kembali.');
                    localStorage.removeItem('token');
                    window.location.href = 'index.html';
                    return;
                }

                const result = await response.json();

                closeModal();

                if (result.success) {
                    showToast('Aset berhasil dihapus!', 'success');
                    fetchAssets();
                } else {
                    showToast('Gagal menghapus: ' + result.message, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                closeModal();
                showToast('Terjadi kesalahan saat menghapus.', 'error');
            } finally {
                btn.textContent = originalText;
                btn.disabled = false;
            }
        });
    </script>
</body>

</html>
