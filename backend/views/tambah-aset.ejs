    <!-- Add Location Modal -->
    <div id="locationModal" class="modal">
        <div class="modal-content form-card" style="max-width: 400px; padding: 24px; position: relative;">
            <span class="modal-close" style="top: 10px; right: 15px; color: #333; font-size: 28px;"
                onclick="closeLocationModal()">&times;</span>
            <h3 style="margin-bottom: 16px;">Tambah Lokasi Baru</h3>
            <div class="form-section">
                <label class="form-label">Nama Lokasi</label>
                <input type="text" id="new_location_name" class="form-input" placeholder="Nama Lokasi">
            </div>
            <div class="form-actions" style="margin-top: 16px; padding-top: 16px;">
                <button type="button" class="btn-secondary" onclick="closeLocationModal()">Batal</button>
                <button type="button" class="btn-primary" onclick="saveNewLocation()">Simpan</button>
            </div>
        </div>
    </div>

    <script src="/js/script.js"></script>
    <script>
        // Check Auth
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = 'index.html';
        }

        // Init saved options
        document.addEventListener('DOMContentLoaded', () => {
            loadSavedOptions('kondisi');
            fetchLocations(); // Fetch locations on load
        });

        // Location Logic
        async function fetchLocations() {
            try {
                const response = await fetch('/api/locations', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await response.json();
                if (result.success) {
                    const select = document.getElementById('location');
                    // Keep first option
                    select.innerHTML = '<option value="">Pilih Lokasi</option>';
                    if (result.locations && Array.isArray(result.locations)) {
                        result.locations.forEach(loc => {
                            const opt = document.createElement('option');
                            opt.value = loc.id;
                            opt.textContent = loc.nama_lokasi;
                            select.appendChild(opt);
                        });
                    }
                }
            } catch (e) {
                console.error("Error fetching locations", e);
            }
        }

        function openAddLocationModal() {
            document.getElementById('locationModal').style.display = 'flex';
            // Flex for centering if needed, or stick to block/css
            document.getElementById('locationModal').style.alignItems = 'center';
            document.getElementById('locationModal').style.justifyContent = 'center';
        }

        function closeLocationModal() {
            document.getElementById('locationModal').style.display = 'none';
        }

        async function saveNewLocation() {
            const name = document.getElementById('new_location_name').value;
            if (!name) return alert("Nama lokasi harus diisi");

            try {
                const response = await fetch('/api/locations/add', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ nama_lokasi: name })
                });

                if (response.status === 401) {
                    alert('Sesi habis. Silakan login kembali.');
                    localStorage.removeItem('token');
                    window.location.href = 'index.html';
                    return;
                }

                const result = await response.json();
                if (result.success) {
                    alert("Lokasi berhasil ditambahkan");
                    document.getElementById('new_location_name').value = '';
                    closeLocationModal();
                    await fetchLocations(); // Refresh list
                    // Auto select new location
                    document.getElementById('location').value = result.location.id;
                } else {
                    alert("Gagal: " + result.message);
                }
            } catch (e) {
                alert("Error koneksi");
            }
        }


        function formatCurrency(input) {
            let value = input.value.replace(/[^0-9]/g, '');
            if (!value) return;
            input.value = new Intl.NumberFormat('en-US').format(value);
        }

        function formatDecimal(input) {
            // Allow digits and one comma
            let value = input.value.replace(/[^0-9,]/g, '');
            // Ensure only one comma
            const parts = value.split(',');
            if (parts.length > 2) {
                value = parts[0] + ',' + parts.slice(1).join('');
            }
            input.value = value;
        }

        function addNewOption(type) {
            if (type !== 'kondisi') return;
            const label = 'Kondisi';
            const newValue = prompt(`Masukkan nama ${label} baru:`);

            if (newValue && newValue.trim() !== "") {
                const selectElement = document.getElementById(type);
                const cleanValue = newValue.trim();
                let exists = false;

                for (let option of selectElement.options) {
                    if (option.value.toLowerCase() === cleanValue.toLowerCase()) {
                        exists = true;
                        break;
                    }
                }

                if (!exists) {
                    const newOption = document.createElement("option");
                    newOption.value = cleanValue;
                    newOption.text = cleanValue;
                    selectElement.add(newOption);
                    selectElement.value = cleanValue;
                    saveOption(type, cleanValue);
                } else {
                    alert(`${label} tersebut sudah ada!`);
                    selectElement.value = cleanValue;
                }
            }
        }

        function saveOption(type, value) {
            const key = `custom_options_${type}`;
            let options = JSON.parse(localStorage.getItem(key)) || [];
            if (!options.includes(value)) {
                options.push(value);
                localStorage.setItem(key, JSON.stringify(options));
            }
        }

        function loadSavedOptions(type) {
            const key = `custom_options_${type}`;
            const options = JSON.parse(localStorage.getItem(key)) || [];
            const selectElement = document.getElementById(type);

            options.forEach(val => {
                let exists = false;
                for (let option of selectElement.options) {
                    if (option.value === val) exists = true;
                }
                if (!exists) {
                    const newOption = document.createElement("option");
                    newOption.value = val;
                    newOption.text = val;
                    selectElement.add(newOption);
                }
            });
        }

        // File Upload Handling
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('foto_aset');
        const previewContainer = document.getElementById('preview-container');

        let allSelectedFiles = [];

        dropZone.addEventListener('click', () => fileInput.click());

        fileInput.addEventListener('change', function () {
            if (this.files) {
                const newFiles = Array.from(this.files);
                const validFiles = newFiles.filter(file => file.type.startsWith('image/'));
                allSelectedFiles = [...allSelectedFiles, ...validFiles];
                renderPreviews();
                this.value = '';
            }
        });

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.style.borderColor = 'var(--primary-color)';
            dropZone.style.background = '#e3f2fd';
        });

        dropZone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            dropZone.style.borderColor = 'var(--border-color)';
            dropZone.style.background = '#f8f9fa';
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.style.borderColor = 'var(--border-color)';
            dropZone.style.background = '#f8f9fa';

            if (e.dataTransfer.files) {
                const newFiles = Array.from(e.dataTransfer.files);
                const validFiles = newFiles.filter(file => file.type.startsWith('image/'));
                allSelectedFiles = [...allSelectedFiles, ...validFiles];
                renderPreviews();
            }
        });

        function renderPreviews() {
            previewContainer.innerHTML = '';
            previewContainer.style.display = allSelectedFiles.length ? 'grid' : 'none';

            allSelectedFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const div = document.createElement('div');
                    div.className = 'preview-item';
                    div.innerHTML = `
                        <img src="${e.target.result}" onclick="openModal('${e.target.result}')" alt="Preview">
                        <button type="button" class="delete-btn" onclick="removeFile(${index})">
                            <i class="ph-bold ph-x"></i>
                        </button>
                    `;
                    previewContainer.appendChild(div);
                }
                reader.readAsDataURL(file);
            });
        }

        window.removeFile = function (index) {
            allSelectedFiles.splice(index, 1);
            renderPreviews();
        }

        const modal = document.getElementById("imageModal");
        const modalImg = document.getElementById("modalImage");
        const span = document.getElementsByClassName("modal-close")[0];

        window.openModal = function (src) {
            modal.style.display = "block";
            modalImg.src = src;
        }

        if (span) {
            span.onclick = function () {
                modal.style.display = "none";
            }
        }

        window.onclick = function (event) {
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }

        document.getElementById('add-asset-form').addEventListener('submit', async function (e) {
            e.preventDefault();

            const btn = this.querySelector('button[type="submit"]');
            const assetNoInput = document.getElementById('asset_no');
            const assetNoVal = assetNoInput.value.trim();

            if (assetNoVal.length !== 12) {
                alert('Kolom "Asset" harus diisi dengan tepat 12 digit angka.');
                assetNoInput.focus();
                return;
            }

            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="ph-bold ph-spinner ph-spin"></i> <span>Menyimpan...</span>';
            btn.disabled = true;

            const form = new FormData(this);
            const data = new FormData();

            data.append('nama', form.get('asset_no') || '-');
            data.append('location_id', document.getElementById('location').value); // Send ID

            data.append('description', form.get('description') || '');
            data.append('keterangan', form.get('keterangan') || '');

            const numericFields = ['acquis_val', 'monthly_dep'];

            for (let [key, value] of form.entries()) {
                if (key === 'foto_aset') continue;

                if (numericFields.includes(key)) {
                    data.append(key, value.replace(/,/g, ''));
                } else if (key === 'quantity') {
                    // Send as is, let backend handle or standardized?
                    // Or replace comma with dot here?
                    // User inputs "2,34". API expects "2.34".
                    data.append(key, value.replace(',', '.'));
                } else if (!data.has(key)) {
                    data.append(key, value);
                }
            }

            if (allSelectedFiles.length > 0) {
                allSelectedFiles.forEach(file => {
                    data.append('images', file);
                });
            }

            try {
                const response = await fetch('/api/assets/add', {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: data
                });

                if (response.status === 401) {
                    alert('Sesi habis. Silakan login kembali.');
                    localStorage.removeItem('token');
                    window.location.href = 'index.html';
                    return;
                }

                const result = await response.json();

                if (result.success) {
                    alert('Aset berhasil ditambahkan!');
                    window.location.href = 'data-aset.html';
                } else {
                    let msg = result.message || 'Gagal menyimpan';
                    if (result.errors && Array.isArray(result.errors)) {
                        msg += '\n' + result.errors.map(e => `- ${e.msg}`).join('\n');
                    }
                    alert(msg);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Terjadi kesalahan koneksi server.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        document.getElementById('logout-btn').addEventListener('click', () => {
            localStorage.removeItem('token');
            window.location.href = 'index.html';
        });
    </script>
</body>

</html>
